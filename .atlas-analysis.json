  "keyFeatures": [
    "DDD building blocks: BaseAggregateRoot, BaseEntity, BaseValueObject, BaseEntityId",
    "Event Sourcing support via BaseEventSourcedAggregateRoot and KurrentDB integration",
    "CQRS with ICommand, IQuery, ICommandBus, IQueryBus interfaces backed by MediatR",
    "MediatR pipeline behaviors for validation, caching, authorization, logging, and unit of work",
    "Entity Framework Core base repositories, DbContexts, and soft-delete interceptor",
    "MassTransit-based integration event/command bus over RabbitMQ",
    "RESTful API helpers: BaseApiCommandController, BaseApiQueryController, ExceptionMiddleware, ResponseBuilder",
    "Business rule enforcement with IBusinessRule and BusinessRuleValidationException",
    "SmartEnum base class wrapping Ardalis.SmartEnum",
    "Partition and user context services for multi-tenant scenarios",
    "Architecture tests enforcing Clean Architecture dependency rules"
  ],
  "publicApiSurface": [
